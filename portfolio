  <script>
    /* ---- Mobile menu ---- */
    const toggle   = document.getElementById('menuToggle');
    const menu     = document.getElementById('mobileMenu');
    const iconB    = document.getElementById('iconBurger');
    const iconX    = document.getElementById('iconX');

    function closeMenu() {
      menu.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
      iconB.style.display = 'block';
      iconX.style.display = 'none';
    }

    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(isOpen));
      iconB.style.display = isOpen ? 'none'  : 'block';
      iconX.style.display = isOpen ? 'block' : 'none';
    });

    document.querySelectorAll('.mm-link').forEach(l => l.addEventListener('click', closeMenu));

    /* ---- Active nav link on scroll ---- */
    const sections = document.querySelectorAll('section[id]');
    const navAs    = document.querySelectorAll('.nav-links a');

    const spy = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        navAs.forEach(a => a.classList.remove('active'));
        const a = document.querySelector(`.nav-links a[href="#${e.target.id}"]`);
        if (a) a.classList.add('active');
      });
    }, { rootMargin: '-42% 0px -54% 0px' });

    sections.forEach(s => spy.observe(s));

    /* ---- Scroll-reveal ---- */
    const revealTargets = document.querySelectorAll(
      '.exp-card, .proj-card, .skill-group, .edu-card, .c-link'
    );

    const reveal = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        e.target.style.opacity   = '1';
        e.target.style.transform = 'translate(0,0)';
        reveal.unobserve(e.target);
      });
    }, { threshold: 0.1 });

    /* Respect prefers-reduced-motion */
    const motion = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (!motion.matches) {
      revealTargets.forEach(el => {
        const isExp = el.classList.contains('exp-card');
        el.style.opacity    = '0';
        el.style.transform  = isExp ? 'translateX(-18px)' : 'translateY(18px)';
        el.style.transition = 'opacity .5s ease, transform .5s ease';
        reveal.observe(el);
      });
    }
  </script>

</body>
