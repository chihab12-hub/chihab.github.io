<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
  <meta name="description" content="Portfolio de Kazi Tani Chihab Eddine – Étudiant MSc AI Applied to Business à Eugenia School, en recherche d'alternance." />
  <meta name="author" content="Kazi Tani Chihab Eddine" />
  <title>Chihab Kazi Tani · Portfolio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <style>
    /* ===== DESIGN TOKENS ===== */
    :root {
      --bg:          #0a0a0a;
      --surface:     #141414;
      --surface-2:   #1e1e1e;
      --accent:      #53c28b;
      --accent-dim:  rgba(83,194,139,.12);
      --accent-glow: rgba(83,194,139,.22);
      --text:        #f0f0f0;
      --text-muted:  #888;
      --border:      rgba(255,255,255,.07);
      --radius:      12px;
      --nav-h:       64px;
      --max-w:       1100px;
      --ease:        cubic-bezier(.4,0,.2,1);
    }

    /* ===== RESET ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
    }
    a  { color: inherit; text-decoration: none; }
    ul { list-style: none; }
    img { max-width: 100%; display: block; }

    /* ===== UTILITIES ===== */
    .container { max-width: var(--max-w); margin: 0 auto; padding: 0 1.35rem; }
    .section    { padding: 5.5rem 0; }

    .section-eyebrow {
      display: inline-block;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: .65rem;
    }
    .section-title {
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      font-weight: 900;
      line-height: 1.1;
      letter-spacing: -.02em;
      margin-bottom: .5rem;
    }
    .section-sub {
      color: var(--text-muted);
      font-size: .95rem;
      max-width: 480px;
      margin-bottom: 3rem;
    }
    .divider { height: 1px; background: var(--border); }

    /* BUTTONS */
    .btn {
      display: inline-flex; align-items: center; gap: .45rem;
      padding: .65rem 1.45rem;
      border-radius: 6px;
      font-size: .88rem;
      font-weight: 700;
      letter-spacing: .01em;
      cursor: pointer;
      border: none;
      transition: background .22s var(--ease), color .22s var(--ease),
                  transform .18s var(--ease), box-shadow .22s var(--ease);
    }
    .btn-primary { background: var(--accent); color: #000; }
    .btn-primary:hover {
      background: #6fe0a4;
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(83,194,139,.25);
    }
    .btn-outline { background: transparent; color: var(--accent); border: 1.5px solid var(--accent); }
    .btn-outline:hover { background: var(--accent-dim); }

    /* TAGS */
    .tag {
      font-size: .7rem;
      font-weight: 700;
      background: var(--accent-dim);
      color: var(--accent);
      padding: .18rem .6rem;
      border-radius: 99px;
      letter-spacing: .04em;
    }

    /* ===== NAVBAR ===== */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      height: var(--nav-h);
      background: rgba(10,10,10,.82);
      backdrop-filter: blur(16px) saturate(1.4);
      -webkit-backdrop-filter: blur(16px) saturate(1.4);
      border-bottom: 1px solid var(--border);
    }
    .nav-inner {
      display: flex; align-items: center; justify-content: space-between;
      height: 100%;
    }
    .nav-logo {
      font-size: 1.15rem; font-weight: 900; letter-spacing: -.03em;
    }
    .nav-logo span { color: var(--accent); }

    .nav-links {
      display: flex; align-items: center; gap: 2rem;
    }
    .nav-links a {
      font-size: .85rem; font-weight: 500;
      color: var(--text-muted);
      transition: color .2s var(--ease);
      position: relative;
    }
    .nav-links a::after {
      content: '';
      position: absolute; bottom: -3px; left: 0; right: 0;
      height: 1.5px;
      background: var(--accent);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform .25s var(--ease);
    }
    .nav-links a:hover { color: var(--accent); }
    .nav-links a:hover::after, .nav-links a.active::after { transform: scaleX(1); }
    .nav-links a.active { color: var(--accent); }

    .nav-socials { display: flex; align-items: center; gap: .9rem; }
    .nav-socials a {
      color: var(--text-muted);
      transition: color .2s var(--ease);
      display: flex; align-items: center;
    }
    .nav-socials a:hover { color: var(--accent); }

    .nav-toggle {
      display: none;
      background: none; border: none; cursor: pointer;
      color: var(--text); padding: .3rem;
    }

    /* MOBILE MENU */
    .mobile-menu {
      display: none;
      position: fixed; top: var(--nav-h); left: 0; right: 0; z-index: 190;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 1.6rem 1.35rem;
      flex-direction: column;
      gap: 1.2rem;
    }
    .mobile-menu.open { display: flex; }
    .mobile-menu a {
      font-size: 1rem; font-weight: 500;
      color: var(--text-muted);
      transition: color .18s;
    }
    .mobile-menu a:hover { color: var(--accent); }
    .mm-socials {
      display: flex; gap: 1rem; padding-top: .6rem;
      border-top: 1px solid var(--border);
    }
    .mm-socials a { color: var(--text-muted); transition: color .18s; }
    .mm-socials a:hover { color: var(--accent); }

    /* ===== HERO ===== */
    .hero {
      min-height: 100vh;
      display: flex; align-items: center;
      position: relative; overflow: hidden;
      padding-top: var(--nav-h);
    }
    /* decorative circle shape (top-right, like reference site) */
    .hero-shape {
      position: absolute; top: -8%; right: -4%;
      width: 52%; max-width: 680px;
      opacity: .055; pointer-events: none; z-index: 0;
    }
    /* radial green glow behind name */
    .hero-glow {
      position: absolute; top: 46%; left: 38%;
      transform: translate(-50%,-50%);
      width: 640px; height: 640px;
      background: radial-gradient(circle, var(--accent-glow) 0%, transparent 68%);
      pointer-events: none; z-index: 0;
      animation: glowPulse 6s ease-in-out infinite alternate;
    }
    @keyframes glowPulse {
      from { opacity: .45; transform: translate(-50%,-50%) scale(1); }
      to   { opacity: .75; transform: translate(-50%,-50%) scale(1.1); }
    }

    .hero-content { position: relative; z-index: 1; }
    .hero-greeting {
      font-size: 1.05rem; font-weight: 500;
      color: var(--text-muted); margin-bottom: .75rem;
    }
    .hero-name {
      font-size: clamp(2.8rem, 7.5vw, 5.8rem);
      font-weight: 900;
      line-height: 1.04;
      letter-spacing: -.035em;
      margin-bottom: 1.3rem;
    }
    .hero-name .hl { color: var(--accent); }

    .hero-pitch {
      font-size: clamp(.95rem, 2vw, 1.15rem);
      color: var(--text-muted);
      max-width: 560px;
      line-height: 1.75;
      margin-bottom: 2.2rem;
    }
    .hero-pitch strong { color: var(--text); }

    .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

    /* scroll indicator */
    .hero-scroll {
      position: absolute; bottom: 2rem; left: 50%;
      transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: .35rem;
      color: var(--text-muted); font-size: .65rem; letter-spacing: .14em; text-transform: uppercase;
      animation: scrollBounce 2.6s ease-in-out infinite;
    }
    @keyframes scrollBounce {
      0%,100% { transform: translateX(-50%) translateY(0); }
      50%      { transform: translateX(-50%) translateY(7px); }
    }

    /* ===== ABOUT ===== */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }
    .about-text p { color: var(--text-muted); line-height: 1.82; margin-bottom: 1rem; }
    .about-text strong { color: var(--text); }
    .about-ctas { display: flex; gap: .75rem; flex-wrap: wrap; margin-top: 1.5rem; }

    /* Education cards */
    .edu-list { display: flex; flex-direction: column; gap: 1.1rem; }
    .edu-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.2rem 1.4rem 1.2rem 1.6rem;
      position: relative; overflow: hidden;
      transition: border-color .22s var(--ease);
    }
    .edu-card::before {
      content: '';
      position: absolute; left: 0; top: 0; bottom: 0;
      width: 3px;
      background: var(--accent);
      border-radius: 3px 0 0 3px;
    }
    .edu-card:hover { border-color: rgba(83,194,139,.45); }
    .edu-date   { font-size: .68rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--accent); margin-bottom: .28rem; }
    .edu-degree { font-weight: 700; font-size: .93rem; margin-bottom: .18rem; }
    .edu-school { font-size: .8rem; color: var(--text-muted); }
    .edu-badge  {
      display: inline-block; margin-top: .55rem;
      font-size: .68rem; font-weight: 700;
      background: var(--accent-dim); color: var(--accent);
      padding: .15rem .65rem; border-radius: 99px;
    }

    /* ===== EXPERIENCE ===== */
    .exp-list { display: flex; flex-direction: column; gap: 1.4rem; }
    .exp-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.75rem;
      transition: border-color .22s var(--ease), transform .22s var(--ease);
    }
    .exp-card:hover { border-color: rgba(83,194,139,.45); transform: translateX(5px); }

    .exp-head {
      display: flex; align-items: flex-start;
      justify-content: space-between; gap: 1rem;
      flex-wrap: wrap; margin-bottom: .8rem;
    }
    .exp-title   { font-weight: 800; font-size: 1.02rem; }
    .exp-company { color: var(--accent); font-weight: 600; font-size: .88rem; margin-top: .18rem; }
    .exp-period  {
      font-size: .72rem; font-weight: 700; letter-spacing: .06em;
      color: var(--text-muted); background: var(--surface-2);
      padding: .25rem .8rem; border-radius: 99px; white-space: nowrap; flex-shrink: 0;
    }

    .exp-bullets { padding-left: .5rem; display: flex; flex-direction: column; gap: .35rem; }
    .exp-bullets li {
      position: relative; padding-left: 1.1rem;
      color: var(--text-muted); font-size: .88rem; line-height: 1.68;
    }
    .exp-bullets li::before { content: '▹'; position: absolute; left: 0; color: var(--accent); }

    .exp-tags { display: flex; flex-wrap: wrap; gap: .45rem; margin-top: 1rem; }

    /* ===== PROJECTS ===== */
    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1.4rem;
    }
    .proj-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.7rem;
      display: flex; flex-direction: column; gap: 1rem;
      transition: border-color .22s var(--ease), transform .22s var(--ease);
    }
    .proj-card:hover { border-color: rgba(83,194,139,.45); transform: translateY(-5px); }

    .proj-icon {
      width: 46px; height: 46px;
      background: var(--accent-dim); border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem;
    }
    .proj-title { font-weight: 800; font-size: .97rem; }
    .proj-desc  { color: var(--text-muted); font-size: .86rem; line-height: 1.72; flex: 1; }

    .proj-foot {
      display: flex; align-items: center;
      justify-content: space-between; flex-wrap: wrap; gap: .5rem;
    }
    .proj-tags { display: flex; flex-wrap: wrap; gap: .4rem; }
    .proj-link {
      font-size: .78rem; font-weight: 700; color: var(--accent);
      display: flex; align-items: center; gap: .3rem;
      transition: gap .18s var(--ease);
    }
    .proj-link:hover { gap: .5rem; }

    /* ===== SKILLS ===== */
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
      gap: 1.3rem;
    }
    .skill-group {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.4rem 1.5rem;
      transition: border-color .22s;
    }
    .skill-group:hover { border-color: rgba(83,194,139,.3); }
    .sg-title {
      font-size: .7rem; font-weight: 700;
      letter-spacing: .14em; text-transform: uppercase;
      color: var(--accent); margin-bottom: .9rem;
    }
    .sg-tags { display: flex; flex-wrap: wrap; gap: .45rem; }
    .sg-tag {
      font-size: .78rem; font-weight: 500;
      background: var(--surface-2); color: var(--text);
      padding: .28rem .7rem; border-radius: 6px;
      border: 1px solid var(--border);
      transition: border-color .18s, color .18s;
    }
    .sg-tag:hover { border-color: var(--accent); color: var(--accent); }

    /* ===== CONTACT ===== */
    .contact-wrap { max-width: 640px; margin: 0 auto; text-align: center; }
    .contact-links {
      display: flex; flex-wrap: wrap;
      justify-content: center; gap: 1rem; margin-top: 2.5rem;
    }
    .c-link {
      display: flex; align-items: center; gap: .6rem;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: .85rem 1.4rem;
      font-weight: 500; font-size: .88rem;
      transition: border-color .2s, color .2s, transform .2s var(--ease);
    }
    .c-link:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }

    /* ===== FOOTER ===== */
    footer {
      border-top: 1px solid var(--border);
      padding: 3rem 0 1.5rem;
      position: relative; overflow: hidden;
    }
    .footer-bg-shape {
      position: absolute; bottom: -5%; right: -3%;
      width: 36%; opacity: .045; pointer-events: none;
    }
    .footer-top {
      display: flex; align-items: flex-start;
      justify-content: space-between; flex-wrap: wrap; gap: 1.8rem;
      position: relative; z-index: 1; margin-bottom: 2.5rem;
    }
    .f-logo       { font-size: 1.05rem; font-weight: 900; letter-spacing: -.02em; }
    .f-logo span  { color: var(--accent); }
    .f-tagline    { color: var(--text-muted); font-size: .8rem; margin-top: .25rem; max-width: 300px; }
    .f-links      { display: flex; gap: 1.5rem; flex-wrap: wrap; }
    .f-links a    { font-size: .82rem; color: var(--text-muted); transition: color .18s; }
    .f-links a:hover { color: var(--accent); }
    .f-socials    { display: flex; gap: .9rem; }
    .f-socials a  { color: var(--text-muted); transition: color .18s; display: flex; }
    .f-socials a:hover { color: var(--accent); }
    .footer-copy  {
      text-align: center; color: var(--text-muted);
      font-size: .76rem; padding-top: 1.5rem;
      border-top: 1px solid var(--border);
      position: relative; z-index: 1;
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 820px) {
      .nav-links, .nav-socials { display: none; }
      .nav-toggle { display: flex; }
    }
    @media (max-width: 700px) {
      .about-grid       { grid-template-columns: 1fr; gap: 2.5rem; }
      .section          { padding: 3.8rem 0; }
      .projects-grid    { grid-template-columns: 1fr; }
      .skills-grid      { grid-template-columns: 1fr 1fr; }
      .footer-top       { flex-direction: column; }
      .exp-head         { flex-direction: column; }
      .hero-scroll      { display: none; }
    }
    @media (max-width: 480px) {
      .skills-grid    { grid-template-columns: 1fr; }
      .contact-links  { flex-direction: column; }
      .hero-ctas      { flex-direction: column; }
      .about-ctas     { flex-direction: column; }
    }

    /* ===== REDUCED MOTION ===== */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: .01ms !important;
        transition-duration: .01ms !important;
      }
      html { scroll-behavior: auto; }
    }
  </style>
</head>
